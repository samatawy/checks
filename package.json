{
    "name": "@samatawy/checks",
    "version": "0.2.5",
    "description": "TypeScript validation and object-management library with fluent checks, object factories, coded results, and lightweight typed cache/store helpers.",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./node": {
            "types": "./dist/node.d.ts",
            "import": "./dist/node.js",
            "require": "./dist/node.cjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "clean": "rimraf dist",
        "build": "tsup src/index.ts src/node.ts --format esm,cjs --dts --clean",
        "dev": "tsup src/index.ts src/node.ts --format esm,cjs --dts --watch",
        "lint": "tsc --noEmit -p tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "docs": "typedoc",
        "prepublishOnly": "npm run lint && npm run test && npm run build"
    },
    "keywords": [
        "typescript",
        "npm",
        "library",
        "json",
        "validation",
        "json",
        "schema",
        "jsonschema",
        "decorators",
        "checks",
        "factory"
    ],
    "author": "Sam Atawy <sam.atawy@gmail.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/samatawy/checks.git"
    },
    "bugs": {
        "url": "https://github.com/samatawy/checks/issues"
    },
    "homepage": "https://samatawy.github.io/checks/",
    "devDependencies": {
        "@types/node": "^24.3.1",
        "@types/probe-image-size": "^7.2.5",
        "rimraf": "^6.0.1",
        "tsup": "^8.5.0",
        "typedoc": "^0.28.18",
        "typescript": "^5.9.2",
        "vitest": "^3.2.4"
    },
    "peerDependencies": {
        "file-type": "^21.3.4",
        "probe-image-size": "^7.2.3"
    },
    "peerDependenciesMeta": {
        "file-type": {
            "optional": true
        },
        "probe-image-size": {
            "optional": true
        }
    }
}